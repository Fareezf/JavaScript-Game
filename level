<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Interface</title>
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background-color: #f0f0f0;
            font-family: Arial, sans-serif;
        }
        .outer-box {
            border: 2px solid #000;
            border-radius: 20px; /* Outer box border radius */
            padding: 20px;
            background-color: #fff;
            position: relative;
            width: 350px;
            text-align: center;
        }
        .inner-box {
            border: 1px solid #ccc;
            border-radius: 10px; /* Inner box border radius */
            margin: 5px;
            padding: 10px;
            display: inline-block;
            width: 25px;
            height: 25px;
            line-height: 25px;
            font-weight: bold;
            background-color: #e0e0e0;
        }
        .button {
            position: absolute;
            bottom: 10px;
            left: 10px;
            background-color: black;
            color: white;
            border: none;
            border-radius: 5px;
            padding: 10px 15px;
            cursor: pointer;
        }
        .score {
            margin: 10px 0;
            font-size: 18px;
        }
        .hearts {
            margin: 10px 0;
        }
        .heart {
            color: red;
            font-size: 20px;
        }
    </style>
</head>
<body>

<div class="outer-box">
    <div class="score">Score: 100</div>
    <div class="hearts">
        <span class="heart">❤️</span>
        <span class="heart">❤️</span>
        <span class="heart">❤️</span>
    </div>
    <div class="levels">
        <div class="inner-box">1</div>
        <div class="inner-box">2</div>
        <div class="inner-box">3</div>
        <div class="inner-box">4</div>
        <div class="inner-box">5</div>
        <div class="inner-box">6</div>
        <div class="inner-box">7</div>
        <div class="inner-box">8</div>
        <div class="inner-box">9</div>
        <div class="inner-box">10</div>
    </div>
    <button class="button">Click Me</button>
</div>

</body>
</html>